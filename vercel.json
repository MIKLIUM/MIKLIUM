{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1",
      "check": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/404.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/404.js"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type" 
        }
      ]
    }
  ]
}